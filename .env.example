# ==============================================================================
# py_img_scaler Environment Configuration Example
# Copy this file to '.env' and modify paths according to your target host system.
# ==============================================================================

# Custom source directory containing your input photographs (Absolute or Relative paths)
# Default if left blank: input_photos/
PYIMG_SOURCE_DIR=input_photos

# Custom destination directory where upscaled frames are rendered
# Default if left blank: output_upscaled_photos/
PYIMG_DEST_DIR=output_upscaled_photos

# Custom model choice for upscaling (0, 1, or 2)
# Default if left blank: 1
# 0: Smallest footprint, least resource intensive.
# 1: Balanced architecture.
# 2: Most performant model; can heavily tax or crash low-VRAM systems.
PYIMG_MODEL=2

# Target resolution configuration details
# Enforces bounds constraint values down to the core inference layer
# Defaults if left blank: 1920x1080 (1080p canvas)
PYIMG_WIDTH=5120
PYIMG_HEIGHT=2160

# Processing window tile footprint size
# Limits matrix sizes processed simultaneously on the GPU device allocation block
# Default if left blank: 400
PYIMG_TILE_SIZE=400

# Global logger tracking verbosity level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG